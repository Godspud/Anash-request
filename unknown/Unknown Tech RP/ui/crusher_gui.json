{
  "namespace": "um_crusher",
  "crusher_text": {
    "type": "label",
    "text": "Crusher",
    "color": "$title_text_color",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [
      -7,
      -13
    ],
    "layer": 10
  },
  "indicator": {
    "type": "image",
    "texture": "$path",
    "$max_count": 63.0,
    "clip_pixelperfect": false,
    "keep_ratio": false,
    "bindings": [
      {
        "binding_name": "#inventory_stack_count",
        "binding_name_override": "#stack_count",
        "binding_condition": "always",
        "binding_type": "collection",
        "binding_collection_name": "container_items"
      },
      {
        "binding_type": "view",
        "source_property_name": "(not (#stack_count = ''))",
        "target_property_name": "#visible"
      },
      {
        "binding_type": "view",
        "source_property_name": "((#stack_count - '§r' - '§f' - '§o') * 1)",
        "target_property_name": "#stack_number"
      },
      {
        "binding_condition": "always",
        "binding_type": "view",
        "source_property_name": "(1 - ((#stack_number - 1) / $max_count))",
        "target_property_name": "#clip_ratio"
      }
    ]
  },
  "crusher_panel": {
    "type": "collection_panel",
    "collection_name": "container_items",
    "$item_collection_name": "container_items",
    "anchor_from": "left_bottom",
    "anchor_to": "left_bottom",
    "size": [
      176,
      166
    ],
    "controls": [
      {
        "background": {
          "type": "image",
          "texture": "textures/gui/crusher_gui",
          "uv": [
            0,
            0
          ],
          "uv_size": [
            176,
            166
          ],
          "anchor_from": "left_bottom",
          "anchor_to": "left_bottom"
        }
      },
      {
        "energy_bar@um_crusher.indicator": {
          "size": [
            12,
            70
          ],
          "offset": [
            -70,
            0
          ],
          "$path": "textures/ui/energy_indicator",
          "clip_direction": "down",
          "anchor_from": "center",
          "anchor_to": "center",
          "layer": 2
        }
      },
      {
        "item@common.container_item": {
          "collection_index": 0,
          "offset": [
            0,
            -30
          ],
          "anchor_from": "center",
          "anchor_to": "center"
        }
      },
      {
        "item@common.container_item": {
          "collection_index": 1,
          "offset": [
            0,
            30
          ],
          "anchor_from": "center",
          "anchor_to": "center"
        }
      },
      {
        "item@common.container_item": {
          "collection_index": 2,
          "offset": [
            40,
            -5
          ],
          "anchor_from": "center",
          "anchor_to": "center"
        }
      },
      {
        "vertical_progress@um_crusher.indicator": {
          "size": [
            8,
            40
          ],
          "offset": [
            0,
            0
          ],
          "$path": "textures/gui/crusher_gui",
          "uv": [
            176,
            0
          ],
          "uv_size": [
            8,
            40
          ],
          "clip_direction": "up",
          "anchor_from": "center",
          "anchor_to": "center",
          "layer": 3
        }
      },
      {
        "horizontal_progress@um_crusher.indicator": {
          "size": [
            40,
            8
          ],
          "offset": [
            20,
            -5
          ],
          "$path": "textures/gui/crusher_gui",
          "uv": [
            176,
            50
          ],
          "uv_size": [
            40,
            8
          ],
          "clip_direction": "right",
          "anchor_from": "center",
          "anchor_to": "center",
          "layer": 3
        }
      }
    ]
  },
  "main_test_panel": {
    "type": "panel",
    "controls": [
      {
        "container_gamepad_helpers@common.container_gamepad_helpers": {}
      },
      {
        "flying_item_renderer@common.flying_item_renderer": {
          "layer": 14
        }
      },
      {
        "selected_item_details_factory@common.selected_item_details_factory": {}
      },
      {
        "item_lock_notification_factory@common.item_lock_notification_factory": {}
      },
      {
        "root_panel@common.root_panel": {

{
    "namespace": "um_alloy_smelter",
    "bonsai_text": {
      "type": "label",
      "text": "Alloy Smelter",
      "color": "$title_text_color",
      "anchor_from": "top_left",
      "anchor_to": "top_left",
      "layer": 10
    },
    "energy_info": {
      "type": "label",
      "text": "#hover_text",
      "color": "$title_text_color",
      "anchor_from": "top_left",
      "anchor_to": "top_left",
      "layer": 10,
      "bindings": [
      {
      "binding_name": "#hover_text",
      "binding_condition": "always",  
      "binding_type": "collection",
      "binding_collection_name": "container_items"
      }
      ]
    },
   "energy_indicator": {
    "type": "image",
    "texture": "textures/ui/energy_indicator",
    "$max_count": 63.0,
    "clip_direction": "down",
    "uv": [27,10],
    "uv_size": [11,44],
   // "tiled": true,
   "keep_ratio": false,
    "clip_pixelperfect": true,
    "bindings": [
        {
                                                    "binding_name": "#inventory_stack_count",
                                                    "binding_name_override": "#stack_count",
                                                    "binding_condition": "always",  
                                                    "binding_type": "collection",
                                                    "binding_collection_name": "container_items"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "(not (#stack_count = ''))",
                                                    "target_property_name": "#visible"
                                                },
                                                {
                                                    "binding_type": "view",
                                                    "source_property_name": "((#stack_count - '§r' - '§f' - '§o') * 1)",
                                                    "target_property_name": "#stack_number"
                                                },
                                                {
                                                    "binding_condition": "always",
                                                    "binding_type": "view",
                                                    "source_property_name": "(1 - ((#stack_number - 1) / $max_count))",
                                                    "target_property_name": "#clip_ratio"
                                                }
    
     ]
    },
    "bonsai_tree_icon": {
      "type": "image",
      "texture": "textures/ui/Sapling_icon",
      "anchor_from": "center",
      "anchor_to": "center"
    },
